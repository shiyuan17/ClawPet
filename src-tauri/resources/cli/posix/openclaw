#!/bin/sh
# OpenClaw CLI wrapper managed by DragonClaw

SCRIPT="$0"
while [ -L "$SCRIPT" ]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"
  SCRIPT="$(readlink "$SCRIPT")"
  [ "${SCRIPT#/}" = "$SCRIPT" ] && SCRIPT="$SCRIPT_DIR/$SCRIPT"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"

version_part() {
  version="$1"
  field="$2"
  value="$(printf '%s' "$version" | cut -d. -f"$field" | sed 's/[^0-9].*$//')"
  if [ -z "$value" ]; then
    value="0"
  fi
  printf '%s' "$value"
}

version_gt() {
  left="$1"
  right="$2"

  left_major="$(version_part "$left" 1)"
  right_major="$(version_part "$right" 1)"
  if [ "$left_major" -gt "$right_major" ]; then
    return 0
  fi
  if [ "$left_major" -lt "$right_major" ]; then
    return 1
  fi

  left_minor="$(version_part "$left" 2)"
  right_minor="$(version_part "$right" 2)"
  if [ "$left_minor" -gt "$right_minor" ]; then
    return 0
  fi
  if [ "$left_minor" -lt "$right_minor" ]; then
    return 1
  fi

  left_patch="$(version_part "$left" 3)"
  right_patch="$(version_part "$right" 3)"
  if [ "$left_patch" -gt "$right_patch" ]; then
    return 0
  fi

  return 1
}

resolve_entry() {
  for root in \
    "$SCRIPT_DIR" \
    "$SCRIPT_DIR/.." \
    "$SCRIPT_DIR/../.." \
    "$SCRIPT_DIR/../../.."
  do
    if [ -f "$root/openclaw/openclaw.mjs" ]; then
      echo "$root/openclaw/openclaw.mjs"
      return 0
    fi
    if [ -f "$root/resources/openclaw/openclaw.mjs" ]; then
      echo "$root/resources/openclaw/openclaw.mjs"
      return 0
    fi
  done
  return 1
}

resolve_node() {
  if [ -n "$OPENCLAW_NODE_PATH" ] && [ -x "$OPENCLAW_NODE_PATH" ]; then
    echo "$OPENCLAW_NODE_PATH"
    return 0
  fi

  BEST_NODE_BIN=""
  BEST_NODE_VERSION=""
  consider_node_candidate() {
    candidate="$1"
    if [ ! -x "$candidate" ]; then
      return
    fi

    candidate_version="$("$candidate" -v 2>/dev/null | tr -d '\r' | sed 's/^v//')"
    if [ -z "$candidate_version" ]; then
      return
    fi

    if [ -z "$BEST_NODE_BIN" ] || version_gt "$candidate_version" "$BEST_NODE_VERSION"; then
      BEST_NODE_BIN="$candidate"
      BEST_NODE_VERSION="$candidate_version"
    fi
  }

  ENTRY_DIR="$(dirname "$1")"
  for node_bin in \
    "$ENTRY_DIR/../bin/node" \
    "$ENTRY_DIR/../../bin/node"
  do
    consider_node_candidate "$node_bin"
  done

  OLD_IFS="$IFS"
  IFS=':'
  for path_dir in $PATH; do
    [ -z "$path_dir" ] && continue
    consider_node_candidate "$path_dir/node"
  done
  IFS="$OLD_IFS"

  if [ -n "$BEST_NODE_BIN" ]; then
    echo "$BEST_NODE_BIN"
    return 0
  fi

  return 1
}

ENTRY="$(resolve_entry)"
if [ -z "$ENTRY" ]; then
  echo "Error: bundled openclaw.mjs not found." >&2
  exit 1
fi

NODE_BIN="$(resolve_node "$ENTRY")"
if [ -z "$NODE_BIN" ]; then
  echo "Error: Node.js binary not found. Set OPENCLAW_NODE_PATH or install node." >&2
  exit 1
fi

case "$1" in
  update)
    echo "openclaw is managed by DragonClaw (bundled runtime)."
    "$NODE_BIN" "$ENTRY" --version 2>/dev/null || true
    exit 0
    ;;
esac

export OPENCLAW_EMBEDDED_IN="DragonClaw"
export OPENCLAW_NO_RESPAWN="1"
exec "$NODE_BIN" "$ENTRY" "$@"
