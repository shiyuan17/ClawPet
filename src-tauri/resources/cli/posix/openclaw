#!/bin/sh
# OpenClaw CLI wrapper managed by ClawPet

SCRIPT="$0"
while [ -L "$SCRIPT" ]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"
  SCRIPT="$(readlink "$SCRIPT")"
  [ "${SCRIPT#/}" = "$SCRIPT" ] && SCRIPT="$SCRIPT_DIR/$SCRIPT"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"

resolve_entry() {
  for root in \
    "$SCRIPT_DIR" \
    "$SCRIPT_DIR/.." \
    "$SCRIPT_DIR/../.." \
    "$SCRIPT_DIR/../../.."
  do
    if [ -f "$root/openclaw/openclaw.mjs" ]; then
      echo "$root/openclaw/openclaw.mjs"
      return 0
    fi
    if [ -f "$root/resources/openclaw/openclaw.mjs" ]; then
      echo "$root/resources/openclaw/openclaw.mjs"
      return 0
    fi
  done
  return 1
}

resolve_node() {
  if [ -n "$OPENCLAW_NODE_PATH" ] && [ -x "$OPENCLAW_NODE_PATH" ]; then
    echo "$OPENCLAW_NODE_PATH"
    return 0
  fi

  ENTRY_DIR="$(dirname "$1")"
  for node_bin in \
    "$ENTRY_DIR/../bin/node" \
    "$ENTRY_DIR/../../bin/node"
  do
    if [ -x "$node_bin" ]; then
      echo "$node_bin"
      return 0
    fi
  done

  if command -v node >/dev/null 2>&1; then
    command -v node
    return 0
  fi

  return 1
}

ENTRY="$(resolve_entry)"
if [ -z "$ENTRY" ]; then
  echo "Error: bundled openclaw.mjs not found." >&2
  exit 1
fi

NODE_BIN="$(resolve_node "$ENTRY")"
if [ -z "$NODE_BIN" ]; then
  echo "Error: Node.js binary not found. Set OPENCLAW_NODE_PATH or install node." >&2
  exit 1
fi

case "$1" in
  update)
    echo "openclaw is managed by ClawPet (bundled runtime)."
    "$NODE_BIN" "$ENTRY" --version 2>/dev/null || true
    exit 0
    ;;
esac

export OPENCLAW_EMBEDDED_IN="ClawPet"
export OPENCLAW_NO_RESPAWN="1"
exec "$NODE_BIN" "$ENTRY" "$@"
