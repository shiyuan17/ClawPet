{
  "name": "DragonClaw",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/vue-tsc/bin/vue-tsc.js --noEmit && node ./node_modules/vite/bin/vite.js build",
    "build:lib": "node ./node_modules/vite/bin/vite.js build --config vite.lib.config.ts",
    "build:all": "npm run build && npm run build:lib",
    "bundle:openclaw": "node scripts/bundle-openclaw.mjs",
    "bundle:openclaw-plugins": "node scripts/bundle-openclaw-plugins.mjs",
    "bundle:openclaw:all": "npm run bundle:openclaw && npm run bundle:openclaw-plugins",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "tauri": "CI=false tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "CI=false tauri build",
    "tauri:build:win": "bash ./scripts/tauri-build-win.sh x86_64-pc-windows-msvc",
    "tauri:build:win:arm64": "bash ./scripts/tauri-build-win.sh aarch64-pc-windows-msvc"
  },
  "dependencies": {
    "gsap": "^3.12.7",
    "pinia": "^3.0.1",
    "pixi.js": "^8.9.1",
    "qrcode": "^1.5.4",
    "remotion": "^4.0.434",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@larksuite/openclaw-lark": "2026.3.25",
    "@sliverp/qqbot": "^1.5.4",
    "@soimy/dingtalk": "^3.1.4",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^22.13.10",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^5.2.1",
    "@wecom/wecom-openclaw-plugin": "^1.0.11",
    "openclaw": "^2026.3.28",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vue-tsc": "^2.2.8"
  }
}
